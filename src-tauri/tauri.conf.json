{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClickPro",
  "version": "2.0.0",
  "identifier": "com.clickpro.core",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ClickPro",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Potencore",
    "shortDescription": "Gesti\u00f3n local de empresa \u2014 ClickPro",
    "longDescription": "ClickPro es una aplicaci\u00f3n de escritorio local para gesti\u00f3n de facturas, presupuestos y clientes. Datos almacenados en SQLite en tu equipo.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "fs": {},
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/reservaselrinconcito-stack/clickpro-app/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJERkQ4MkYzNTVCRERBMDUKUldRRjJyMVY4NEw5dmE0RUpwRzNPRDFmakJjZzNZUEdlcHBuS3RTUjI0RGxyUTFRaDdGTHdHM2kK"
    }
  }
}