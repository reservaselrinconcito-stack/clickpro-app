{
  "name": "contigo-reservation-api",
  "version": "2.4.1",
  "private": true,
  "scripts": {
    "dev":    "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create contigo-peluqueria-data",
    "db:apply":  "wrangler d1 execute contigo-peluqueria-data --file=migrations/d1-schema.sql --remote",
    "db:apply:local": "wrangler d1 execute contigo-peluqueria-data --file=migrations/d1-schema.sql --local",
    "db:query":  "wrangler d1 execute contigo-peluqueria-data --command",
    "test:health":   "curl -s https://contigo-reservation-api.TU-CUENTA.workers.dev/health | jq",
    "test:services": "curl -s https://contigo-reservation-api.TU-CUENTA.workers.dev/services | jq"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0"
  }
}
